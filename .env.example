# Stripe Keys — add to Supabase Edge Function secrets
# Dashboard: https://supabase.com/dashboard/project/ldzzlndsspkyohvzfiiu/settings/vault
STRIPE_PUBLIC_KEY=pk_live_xxx
STRIPE_SECRET_KEY=sk_live_xxx

# These are set as Supabase Edge Function secrets via:
#   supabase secrets set STRIPE_SECRET_KEY=sk_live_xxx
#
# The public key is only needed if you switch to Stripe Elements (embedded).
# With Stripe Checkout (redirect), only the secret key is needed server-side.
